{
  "expo": {
    "name": "Capital Analytics",
    "slug": "wccapitalanalytics",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "capital-analytics",
    "userInterfaceStyle": "automatic",

    "icon": "./assets/images/icon.png",

    "android": {
      "package": "com.sainbunty000.capitalanalytics",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": ["READ_EXTERNAL_STORAGE"]
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sainbunty000.capitalanalytics",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select financial documents for analysis"
      }
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-document-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
        "projectId": "66827622-b4e6-44e0-ab45-9dde3621732c"
      }
    }
  }
}
