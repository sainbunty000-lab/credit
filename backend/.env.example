# Environment variables for the backend
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017
DB_NAME=financial_analytics

# AI API Keys (at least one required for document parsing and AI insights)
# Gemini (recommended - supports PDF, images, spreadsheets)
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative for Railway deployment
AI_INTEGRATIONS_GEMINI_API_KEY=

# OpenAI (fallback - images only)
OPENAI_API_KEY=

# Server port (default: 8000)
PORT=8000
